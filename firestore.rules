rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == 'bafanamay585@gmail.com' ||
        request.auth.token.email.matches('.*servant.*') // Temporary bypass for your test accounts
      ); 
    }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isRole(role) { return isSignedIn() && getUserData().role == role; }
    function isAdmin() { return isRole('admin'); }
    function isStaff() { return isRole('staff'); }
    function isManager() { return isAdmin() || isStaff(); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // USER PROFILES
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                       (incoming().role == 'customer' || 
                        (incoming().role == 'admin' && (request.auth.token.email.matches('.*admin.*') || request.auth.token.email == 'bafanamay585@gmail.com')) ||
                        (incoming().role == 'staff' && request.auth.token.email.matches('.*staff.*')));
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
      );
    }

    // MENU
    function isValidMenuItem(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'costPrice', 'category', 'isAvailable']) &&
             data.keys().size() <= 10 &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.costPrice is number && data.costPrice >= 0 &&
             data.category is string && data.category.size() <= 50 &&
             data.isAvailable is bool;
    }

    match /menu/{itemId} {
      allow read: if true; // Publicly viewable
      allow create: if isManager() && isValidMenuItem(incoming()) && incoming().id == itemId;
      allow update: if isManager() && isValidMenuItem(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['isAvailable', 'updatedAt', 'updatedBy'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['price', 'costPrice', 'name', 'description', 'category', 'updatedAt', 'updatedBy']))
      );
      allow delete: if isManager();
    }

    // ORDERS
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'totalCost', 'timestamp', 'status', 'userId', 'customerEmail']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'accepted', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.userId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isVerified() && isValidOrder(incoming()) && (incoming().timestamp == request.time || incoming().timestamp > 0);
      allow update: if isManager() && isVerified() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow list: if isManager();
      allow get: if isManager();
      allow create: if isManager() && isVerified() && incoming().userId == request.auth.uid;
    }
  }
}
