rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isRole(role) { return isSignedIn() && getUserData().role == role; }
    function isAdmin() { return isRole('admin'); }
    function isStaff() { return isRole('staff'); }
    function isManager() { return isAdmin() || isStaff(); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // USER PROFILES
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // MENU
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isManager();
    }

    // ORDERS
    match /orders/{orderId} {
      allow list: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (isManager() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isManager();
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if isManager();
      allow create: if isManager();
    }
  }
}
